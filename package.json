{
  "name": "operon-labs-contract-incentives",
  "version": "0.1.0",
  "private": true,
  "description": "Policy-gated healthcare operations incentives demo using Hedera Agent Kit.",
  "author": {
    "name": "Pavel Grebenshikov",
    "email": "pavel@trustoperon.com"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/operonmaster/operon-labs-contract-incentives.git"
  },
  "homepage": "https://contract-incentives.demo.labs.operon.cloud/",
  "type": "module",
  "workspaces": [
    "src/apps/web",
    "src/packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @operon-labs/web run dev",
    "dev:simulated": "PAS_STORE_BACKEND=memory UM_REFERENCE_STORE_BACKEND=memory POLICY_STORE_BACKEND=memory PAYMENT_POLICY_STORE_BACKEND=memory PAYMENT_POLICY_EVIDENCE_STORE_BACKEND=memory PAYMENT_INTENT_STORE_BACKEND=memory SPECIALTY_RX_STORE_BACKEND=memory APPEALS_STORE_BACKEND=memory HEDERA_SETTLEMENT_MODE=simulated npm run dev",
    "build": "npm --workspace @operon-labs/web run build",
    "lint": "npm --workspace @operon-labs/web run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && npm --workspace @operon-labs/web run typecheck"
  },
  "overrides": {
    "@grpc/grpc-js": "1.14.4",
    "@grpc/proto-loader": "0.8.1",
    "@hiero-ledger/proto": {
      "protobufjs": "8.6.4"
    },
    "@hiero-ledger/sdk": {
      "@grpc/grpc-js": "1.14.4",
      "protobufjs": "8.6.4"
    },
    "next": {
      "postcss": "8.5.10"
    },
    "ethers": {
      "ws": "8.21.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "24.12.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "happy-dom": "^20.10.6",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": ">=10.8.0"
  }
}
